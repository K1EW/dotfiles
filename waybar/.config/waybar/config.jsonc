{
    "layer": "top",
    "height": 20,
    "spacing": 4,
    "margin-top": 5,
    "margin-left": 5,
    "margin-right": 5,
    "modules-left": [
        "hyprland/workspaces",
        "tray"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "network",
        "disk",
        "cpu",
        "backlight",
        "custom/language", 
        "pulseaudio",
        "battery"
    ],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "active-only": false,
        "all-outputs": true,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "1": "<span>َ°­¹</span>",
            "2": "<span>َ°ˆ¹</span>",
            "3": "<span>ï„،</span>",
            "4": "<span>î‍•</span>",
            "5": "<span>َ±”—</span>",
            "6": "<span>ï„›</span>"
        }
    },
    "tray": {
        "icon-size": 14,
        "spacing": 8
    },
    "disk": {
        "format": "<span color='#202020' bgcolor='#ea6962' > ïˆ³ </span> {free}",
        "interval": 20
    },
    "cpu": {
        "format": "<span color='#202020' bgcolor='#e78a4e' > î‰¦ </span> {usage}%",
        "tooltip": false,
        "interval": 1
    },
    "backlight": {
        "format": "<span color='#202020' bgcolor='#f6c657' > َ°‍ڈ </span> {percent}%",
        "tooltip": false,
        "on-click-right": "~/.config/custom_scripts/wlsunset.sh"
    },
    "custom/language": {
        "exec": "~/.config/waybar/scripts/fcitx5-lang.sh",
        "interval": 1,
        "format": "<span color='#202020' bgcolor='#458588' > âŒ¨ </span> {}",
        "tooltip": false
    },
    "pulseaudio": {
        "format": "<span color='#202020' bgcolor='#83a598' > ï€¨ </span> {volume}%",
        "format-muted": "<span color='#202020' bgcolor='#ea6962' > î»¨ </span> {volume}%",
        "format-bluetooth": "<span color='#202020' bgcolor='#83a598' > َ°‚° </span> {volume}%",
        "format-bluetooth-muted": "<span color='#202020' bgcolor='#ea6962' > َ°‚² </span> {volume}%",
        "format-source": "{volume}% ï„°",
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip": false,
        "max-volume": 130
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "battery": {
        "interval": 1,
        "states": {
            "good": 99,
            "warning": 30,
            "critical": 20
        },
        "format-icons": [
            "َ°‚ژ",
            "َ°پ؛",
            "َ°پ»",
            "َ°پ½",
            "َ°پ¾",
            "َ°پ؟",
            "َ°‚€",
            "َ°‚پ",
            "َ°‚‚",
            "َ°پ¹"
        ],
        "format": "<span color='#202020' bgcolor='#689d6a' > {icon} </span> {capacity}%",
        "format-critical": "<span color='#202020' bgcolor='#cc241d' > {icon} </span> {capacity}%!!",
        "format-warning": "<span color='#202020' bgcolor='#e78a4e' > {icon} </span> {capacity}%",
        "format-full": "<span color='#202020' bgcolor='#689d6a' > {icon} </span> {capacity}%",
        "format-charging": "<span color='#202020' bgcolor='#689d6a' > َ°‚… </span> {capacity}%",
        "format-charging-warning": "<span color='#202020' bgcolor='#e78a4e' > َ°¢‌ </span> {capacity}%",
        "format-charging-critical": "<span color='#202020' bgcolor='#cc241d' > َ°¢œ </span> {capacity}%",
        "format-plugged": "<span color='#202020' bgcolor='#689d6a' > َ°‚… </span> {capacity}%",
        "format-alt": "<span color='#202020' bgcolor='#689d6a' > َ±§¥ </span> {time}",
        "tooltip": false
    },
    "network": {
        "interval": 2,
        "format": "<span color='#202020' bgcolor='#d3869b'> َ±ک– </span> {bandwidthDownBits}",
        "format-wifi": "<span color='#202020' bgcolor='#d3869b'> {icon} </span> {bandwidthDownBits}",
        "format-ethernet": "<span color='#202020' bgcolor='#d3869b'> َ°ˆ€ </span> {bandwidthDownBits}",
        "format-icons": [
            "َ°¤«",
            "َ°¤ں",
            "َ°¤¢",
            "َ°¤¥",
            "َ°¤¨"
        ],
        "tooltip": false,
        "states": {
            "normal": 25
        }
    },
    "clock": {
        "format": "<span color='#202020' bgcolor='#8ec07c' > ïپ³ </span> {:%a %d | %H:%M}",
        "tooltip": false,
        "interval": 1
    }
}
